{
    "manifest_version": 3,
    "name": "Age verification bypass",
    "version": "1.0.5",
    "description": "Skips the age verification screens on various platforms!",
    "author": "🦊 helloyanis",
    "developer": {
        "name": "🦊 helloyanis",
        "url": "https://🦊💻️.ws"
    },
    "browser_specific_settings": {
        "gecko": {
          "id": "helloyanis@ageverif-bypass",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "permissions": [
        "webRequest",
        "webRequestBlocking",
        "webRequestFilterResponse",
        "scripting"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "scripts": [
            "websites/agechecker.net.js",
            "websites/ageverif.com.js",
            "websites/reddit.com.js",
            "websites/aliexpress.com.js"
        ]
    },
    "action": {
        "default_icon": "icon.svg"
    }
}